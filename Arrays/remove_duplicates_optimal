def remdups():
    # two pointer approach to remove duplicates (more optimal)
    arr = list(map(int, input().split()))
    i = 0

    if not arr:
        return
    for j in range(1, len(arr)):
        if arr[j] != arr[i]:
            i += 1
            arr[i] = arr[j]
    print(arr[: i + 1])


remdups()
