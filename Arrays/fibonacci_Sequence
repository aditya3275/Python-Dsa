def fibo_Seq(n):
    a = 0
    b = 1

    if len(n) <= 2:
        return True

    for i in range(2, len(n)):
        if n[a] + n[b] == n[i]:  # or better use n[i-1] + n[i - 2], drop a and b
            a = b
            b = i
        else:
            return False
    return True


if __name__ == "__main__":
    n = list(map(int, input().split()))

    if fibo_Seq(n):
        print("yes")
    else:
        print("no")
