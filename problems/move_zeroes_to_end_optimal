def chocolate(arr):
    j = 0
    for i in range(len(arr)):
        if arr[i] != 0:
            arr[j], arr[i] = arr[i], arr[j]
            j += 1
        if arr[i] == 0:
            pass

    return arr


if __name__ == "__main__":
    arr = list(map(int, input().split()))

    print(chocolate(arr))
