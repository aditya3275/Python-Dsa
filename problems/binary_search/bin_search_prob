def bin_search(n, arr):
    low = 0
    high = len(arr) - 1

    while low <= high:
        mid = low + (high - low) // 2

        if arr[mid] < n:
            low = mid + 1
        elif arr[mid] > n:
            high = mid - 1
        else:
            return mid
    return low


if __name__ == "__main__":
    n = int(input())
    arr = list(map(int, input().split()))

    print(bin_search(n, arr))
