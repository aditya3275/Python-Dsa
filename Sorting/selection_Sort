def selection_Sort(arr):
    n = len(arr)

    for i in range(n):
        min_indx = 0

        for j in range(i + 1, n):
            if arr[j] < min_indx:
                min_indx = arr[j]

        arr[i], arr[min_indx] = arr[min_indx], arr[i]

    return arr


if __name__ == "__main__":
    n = int(input())
    arr = list(map(int, input().split()))
    print(selection_Sort(arr))
