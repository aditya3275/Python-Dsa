def abundant(n):
    # res = []
    sum = 0
    for i in range(1, n):
        if n % i == 0:
            sum += i
    if sum > n:
        return True
    else:
        return False


if __name__ == "__main__":
    n = int(input())

    if abundant(n):
        print(f"{n} is an abundant number")
    else:
        print(f"{n} is not an abundant number")
