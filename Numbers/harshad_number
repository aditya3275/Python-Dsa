def harshad(n):
    orig = n
    res = 0
    while n > 0:
        digit = n % 10
        res += digit
        n //= 10
    if orig % res == 0:
        return True
    else:
        return False


if __name__ == "__main__":
    n = int(input())

    if harshad(n):
        print(f"{n} is a harshad number")
    else:
        print(f"{n} is not a harshad number")
