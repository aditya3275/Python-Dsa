def is_prime(n):
  if n < 2:
    return False

  for i in range(2,int(n**0.5) + 1):
    if n % i == 0:
      return False
  return True

def prime_range(a,b):
  result = []
  for i in range(a,b + 1):
    if is_prime(i):
      result.append(i)
  return result

if __name__ == "__main__":
  a = int(input())
  b = int(input())
  ans = prime_range(a,b)
  print(ans)






