#### to find gcd , we have euclidean approach which is much more faster #########


def find_gcd(a, b):
    while a > 0 and b > 0:
        if a > b:
            a = a % b
        else:
            b = b % a

    if a == 0:
        return b

    return a


if __name__ == "__main__":
    a = int(input())
    b = int(input())

    print(find_gcd(a, b))
