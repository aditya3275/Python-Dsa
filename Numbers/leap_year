def leap_year(n):
    if n % 4 != 0:
        return False
    if n % 4 == 0 and n % 100 != 0:
        return True
    if n % 100 == 0 and n % 400 == 0:
        return True

    return False


if __name__ == "__main__":
    n = int(input())

    if leap_year(n):
        print("yes")
    else:
        print("no")
