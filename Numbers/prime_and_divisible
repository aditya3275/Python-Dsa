def is_p(n):
    if n < 2:
        return False

    for i in range(2, int(n**0.5) + 1):
        if n % i == 0:
            return False
    return True


def div_fac(n):
    if n < 0:
        return False
    for i in range(1, n + 1):
        if n % i == 0:
            if is_p(i):
                print(i)


if __name__ == "__main__":
    n = int(input())

    div_fac(n)
